{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cascadelocalseo",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  }
}
